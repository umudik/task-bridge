{
  "name": "@umudik/task-bridge",
  "version": "0.0.19",
  "description": "Task Bridge — Fookie Cloud epic / task board (opens https://task-bridge.fookiecloud.com).",
  "type": "module",
  "license": "MIT",
  "bin": {
    "task-bridge": "bin/task-bridge.mjs"
  },
  "files": [
    "bin",
    "scripts/postinstall.mjs",
    "apps/backend/dist",
    "apps/backend/public"
  ],
  "engines": {
    "node": ">=26"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.mjs",
    "dev": "node scripts/dev.mjs",
    "build": "npm --prefix apps/web run build && node scripts/copy-web.mjs && npm --prefix apps/backend run build",
    "start": "node bin/task-bridge.mjs",
    "test": "npm --prefix apps/backend run test",
    "lint": "npm --prefix apps/backend run lint && cd apps/mobile && gradlew.bat detekt",
    "mcp:build": "npm --prefix apps/mcp run build",
    "mcp:dev": "npm --prefix apps/mcp run dev",
    "mcp:client": "npm --prefix apps/mcp run client",
    "npm:version": "node scripts/npm-publish-version.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^8.1.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "fastify": "^5.2.1",
    "zod": "^3.24.2"
  }
}
