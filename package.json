{
  "name": "task-bridge",
  "private": true,
  "scripts": {
    "dev": "npm --prefix apps/backend run dev",
    "build": "npm --prefix apps/backend run build",
    "docker:up": "docker compose up --build",
    "docker:up:d": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "lint": "npm run lint:backend && npm run lint:mobile",
    "lint:backend": "npm --prefix apps/backend run lint",
    "lint:mobile": "cd apps/mobile && gradlew.bat detekt"
  }
}
