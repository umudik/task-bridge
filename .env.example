# Local dev (npm run dev)
PORT=3000

# Docker (npm run docker:up)
TASK_BRIDGE_PORT=3000
TASK_BRIDGE_VERSION=0.1.0
TASK_BRIDGE_IMAGE=your-dockerhub-user/task-bridge:latest

# Optional: SQLite path (Docker sets /app/data/bridge.db automatically)
# DATABASE_PATH=./data/bridge.db

# Optional: Docker Hub publish (npm run docker:publish)
# DOCKER_USER=your-dockerhub-user
# Log in once: docker login -u your-dockerhub-user
